# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to Git!
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (choose at least one) ─────────────────────────────────────────────────
# Groq is FREE — sign up at https://console.groq.com → API Keys → Create key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude fallback — optional (haiku is cheapest)
ANTHROPIC_API_KEY=sk-ant-xxxx

# ── Frontend CORS ─────────────────────────────────────────────────────────────
# Your Vercel/Netlify portfolio URL (no trailing slash)
FRONTEND_URL=https://your-portfolio.vercel.app

# ── Database (SQLite default — no changes needed for local dev) ───────────────
DATABASE_URL=sqlite+aiosqlite:///./portfolio.db

# ── Vector store path ─────────────────────────────────────────────────────────
CHROMA_PATH=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Email notifications (optional) ───────────────────────────────────────────
# Gmail: Enable 2FA → Google Account → Security → App Passwords → Mail → Create
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx    # 16-char Gmail App Password (NOT your real password)
NOTIFY_EMAIL=your_email@gmail.com  # Where contact alerts are sent
